{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Astraflow Docs",
  "theme": "mint",
  "colors": {
    "primary": "#111111",
    "light": "#ffffff",
    "dark": "#09090b"
  },
  "logo": {
    "light": "/logo/astraflow-docs-light.svg",
    "dark": "/logo/astraflow-docs-dark.svg"
  },
  "favicon": "/favicon.svg",
  "contextual": {
    "options": ["copy", "download-spec"]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get started",
            "pages": ["index", "quickstart", "authentication"]
          },
          {
            "group": "Concepts",
            "pages": ["concepts/sessions", "concepts/runtime"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/overview",
              "api-reference/platform",
              "api-reference/runtime"
            ]
          },
          {
            "group": "Platform API",
            "openapi": {
              "source": "api-reference/platform-openapi.json",
              "directory": "api-reference/platform"
            }
          },
          {
            "group": "Runtime API",
            "openapi": {
              "source": "api-reference/runtime-openapi.json",
              "directory": "api-reference/runtime"
            }
          }
        ]
      }
    ]
  }
}
